# 🔑 API Keys (Required)
GEMINI_API_KEY=your_gemini_api_key_here
API_KEY=your_gemini_api_key_here

# 🌐 Backend URLs (for production deployment)
PYTHON_BACKEND_URL=https://your-railway-backend.railway.app

# 🚀 Deployment Settings
NODE_ENV=production
PORT=3000

# 📊 ML Model Settings
MODEL_ACCURACY_THRESHOLD=0.8
FRAUD_DETECTION_THRESHOLD=0.7

# Legacy AI Studio variables (can be ignored for manual deployment)
# APP_URL="MY_APP_URL"
